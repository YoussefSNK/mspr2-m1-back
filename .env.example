# ── Backend pays ──────────────────────────────────────────────────
PAYS=bresil

# PostgreSQL
DATABASE_URL=postgresql://futurekawa:futurekawa@db-bresil:5432/futurekawa_bresil

# MQTT — Raspberry Pi (10.3.141.1, fallback : 172.20.10.11)
# En Docker : pointer vers le broker Mosquitto local du conteneur
# En démo avec vrai Raspberry Pi : utiliser l'IP du Pi
MQTT_BROKER_HOST=10.3.141.1
MQTT_BROKER_PORT=1883
# Attention : "futurkawa" sans 'e' — c'est le topic du Raspberry Pi
MQTT_TOPIC_PREFIX=futurkawa

# SMTP (laisser vide pour simuler les emails dans les logs)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@futurekawa.com

EMAIL_RESPONSABLE_BRESIL=responsable.bresil@futurekawa.com
EMAIL_RESPONSABLE_EQUATEUR=responsable.equateur@futurekawa.com
EMAIL_RESPONSABLE_COLOMBIE=responsable.colombie@futurekawa.com

# Scheduler — vérification périodique des lots trop anciens (> 365 j)
SCHEDULER_ENABLED=true
# Intervalle entre deux vérifications, en secondes (défaut : 86400 = 24 h)
SCHEDULER_INTERVAL_SECONDS=86400

# ── Backend central ────────────────────────────────────────────────
BACKEND_BRESIL_URL=http://backend-bresil:8000
BACKEND_EQUATEUR_URL=http://backend-equateur:8000
BACKEND_COLOMBIE_URL=http://backend-colombie:8000
